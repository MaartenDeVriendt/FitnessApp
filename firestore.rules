rules_version = '2';

/**
 * Multi-user isolation: each signed-in user may only access their own data under `users/{uid}`.
 *
 * - `users/{uid}` — profile doc from sign-up
 * - `users/{uid}/settings/*` — weekly program template (`weeklyProgram`)
 * - `users/{uid}/weekLogs/*` — logged weights per week + weekday
 * - `users/{uid}/workouts/*` — legacy workouts (optional)
 *
 * The `{document=**}` rule covers every subcollection and nested doc under that user in one place,
 * so new paths (like `settings/weeklyProgram`) work as soon as you deploy — no easy-to-miss nested block.
 *
 * Deploy: `firebase deploy --only firestore:rules` or paste into Console → Firestore → Rules → Publish.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    // The user’s own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // All subcollections under that user (settings, weekLogs, workouts, …)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
